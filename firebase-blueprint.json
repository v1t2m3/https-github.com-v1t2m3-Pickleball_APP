{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A Pickleball tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["round-robin", "knockout", "group-to-knockout"] },
        "status": { "type": "string", "enum": ["open", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "type", "status", "ownerId"]
    },
    "Participant": {
      "title": "Participant",
      "description": "A player or team in a tournament",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "seed": { "type": "number" }
      },
      "required": ["name"]
    },
    "Match": {
      "title": "Match",
      "description": "A game between two participants",
      "type": "object",
      "properties": {
        "p1Id": { "type": "string" },
        "p2Id": { "type": "string" },
        "p1Score": { "type": "number" },
        "p2Score": { "type": "number" },
        "status": { "type": "string", "enum": ["upcoming", "live", "completed"] },
        "round": { "type": "number" },
        "group": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "winnerId": { "type": "string" }
      },
      "required": ["p1Id", "p2Id", "p1Score", "p2Score", "status"]
    }
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournament metadata"
    },
    "/tournaments/{tournamentId}/participants/{participantId}": {
      "schema": "Participant",
      "description": "Tournament participants"
    },
    "/tournaments/{tournamentId}/matches/{matchId}": {
      "schema": "Match",
      "description": "Tournament matches"
    }
  }
}
